{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created" }
      },
      "required": ["uid", "email"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User's learning progress",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user" },
        "lessonId": { "type": "string", "description": "The ID of the lesson" },
        "completed": { "type": "boolean", "description": "Whether the lesson is completed" },
        "score": { "type": "number", "description": "The score achieved in the lesson" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the progress was last updated" }
      },
      "required": ["userId", "lessonId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/progress/{progressId}": {
      "schema": "Progress",
      "description": "User's progress for a specific lesson"
    }
  }
}
